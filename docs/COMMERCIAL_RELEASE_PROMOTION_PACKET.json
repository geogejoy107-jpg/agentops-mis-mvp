{
  "contract_id": "commercial_release_promotion_packet_v1",
  "status": "blocked_release_promotion_required",
  "updated_at": "2026-06-25",
  "ci_safe": true,
  "read_only": true,
  "description": "Operator-facing packet that aggregates commercial release promotion preflight, local/release-grade receipts, optional external exact-head GitHub Actions readback, and optional real Hermes/OpenClaw runtime acceptance evidence without mutating release receipts or allowing handoff/merge.",
  "source_contracts": [
    "commercial_release_promotion_preflight_v1",
    "commercial_exact_head_ci_evidence_v1",
    "commercial_evidence_receipts_v1",
    "commercial_current_evidence_status_v1",
    "commercial_handoff_status_v1",
    "release_freeze_protocol_v1",
    "merge_readiness_status_v1"
  ],
  "packet_requires": {
    "all_local_receipts_complete": true,
    "gates_with_release_grade_receipts_complete": true,
    "clean_worktree_verified": true,
    "remote_sync_verified": true,
    "exact_head_ci_verified": true,
    "real_runtime_acceptance_verified": true,
    "release_complete": true,
    "commercial_handoff_allowed": true,
    "ready_to_merge": true
  },
  "evidence_inputs": {
    "static_receipts": "docs/COMMERCIAL_EVIDENCE_RECEIPTS.json",
    "promotion_preflight": "docs/COMMERCIAL_RELEASE_PROMOTION_PREFLIGHT.json",
    "external_exact_head_ci": "python3 scripts/commercial_exact_head_ci_evidence.py --from-gh --require-current-head",
    "real_runtime_acceptance": "HERMES_ALLOW_REAL_RUN=true python3 scripts/local_runtime_acceptance.py --live-openclaw --live-hermes --require-hermes-api --openclaw-timeout 300 --hermes-timeout 600 --request-timeout 720"
  },
  "required_commands": [
    "python3 scripts/commercial_release_promotion_packet.py",
    "python3 scripts/commercial_release_promotion_packet.py --include-external-ci-evidence",
    "python3 scripts/commercial_release_promotion_packet_smoke.py",
    "HERMES_ALLOW_REAL_RUN=true python3 scripts/local_runtime_acceptance.py --live-openclaw --live-hermes --require-hermes-api --openclaw-timeout 300 --hermes-timeout 600 --request-timeout 720 > /tmp/agentops-mis-runtime-acceptance.json",
    "python3 scripts/commercial_release_promotion_packet.py --include-external-ci-evidence --runtime-acceptance-json /tmp/agentops-mis-runtime-acceptance.json --require-current-runtime-evidence",
    "python3 scripts/commercial_release_promotion_packet.py --include-external-ci-evidence --runtime-acceptance-json /tmp/agentops-mis-runtime-acceptance.json --require-current-runtime-evidence --require-promotion-packet-ready"
  ],
  "must_not_use": [
    "manual_receipt_promotion_without_ci",
    "uncommitted_dirty_promotion",
    "local_only_release_grade_claim",
    "mock_only_product_claim",
    "release_complete_true_without_preflight",
    "raw_prompts",
    "raw_responses",
    "private_transcripts",
    "token_values"
  ]
}
