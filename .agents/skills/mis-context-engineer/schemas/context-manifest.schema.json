{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentops-mis.local/schemas/context-manifest.v0.2.schema.json",
  "title": "AgentOps MIS Context Manifest v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "manifest_id",
    "objective",
    "project_context",
    "harness",
    "loop",
    "included_items",
    "reused_items",
    "excluded_items",
    "unresolved_questions",
    "budget",
    "cache",
    "performance",
    "iterations",
    "evaluation",
    "safety",
    "evidence_refs",
    "output_hash"
  ],
  "properties": {
    "schema_version": {"const": "0.2"},
    "manifest_id": {"type": "string", "pattern": "^ctx_[A-Za-z0-9._:-]+$"},
    "objective": {"type": "string", "minLength": 1},
    "project_context": {
      "type": "object",
      "required": ["repository", "branch", "commit", "workspace_id"],
      "properties": {
        "repository": {"type": "string"},
        "branch": {"type": "string"},
        "commit": {"type": "string"},
        "workspace_id": {"type": "string"},
        "project_id": {"type": ["string", "null"]},
        "task_id": {"type": ["string", "null"]},
        "agent_id": {"type": ["string", "null"]}
      }
    },
    "harness": {"$ref": "#/$defs/versionedContract"},
    "loop": {
      "type": "object",
      "required": ["name", "hash", "max_iterations"],
      "properties": {
        "name": {"type": "string"},
        "hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "max_iterations": {"type": "integer", "minimum": 1}
      }
    },
    "included_items": {"type": "array", "items": {"$ref": "#/$defs/contextItem"}},
    "reused_items": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
    "excluded_items": {"type": "array", "items": {"$ref": "#/$defs/excludedItem"}},
    "unresolved_questions": {"type": "array", "items": {"type": "string"}},
    "budget": {
      "type": "object",
      "required": ["limit", "reserved_output", "available_input", "stable_prefix_tokens", "full_context_tokens", "delta_context_tokens", "overflow"],
      "properties": {
        "limit": {"type": "integer", "minimum": 1},
        "reserved_output": {"type": "integer", "minimum": 0},
        "available_input": {"type": "integer", "minimum": 0},
        "stable_prefix_tokens": {"type": "integer", "minimum": 0},
        "full_context_tokens": {"type": "integer", "minimum": 0},
        "delta_context_tokens": {"type": "integer", "minimum": 0},
        "overflow": {"type": "boolean"}
      }
    },
    "cache": {
      "type": "object",
      "required": ["stable_prefix_hash", "eligible_items", "hit_items", "hit_rate"],
      "properties": {
        "stable_prefix_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "eligible_items": {"type": "integer", "minimum": 0},
        "hit_items": {"type": "integer", "minimum": 0},
        "hit_rate": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "performance": {
      "type": "object",
      "required": ["wall_time_ms", "candidate_count", "gated_count", "included_count", "token_utilization", "token_efficiency"],
      "properties": {
        "wall_time_ms": {"type": "number", "minimum": 0},
        "candidate_count": {"type": "integer", "minimum": 0},
        "gated_count": {"type": "integer", "minimum": 0},
        "included_count": {"type": "integer", "minimum": 0},
        "token_utilization": {"type": "number", "minimum": 0},
        "token_efficiency": {"type": "number", "minimum": 0}
      }
    },
    "iterations": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/iteration"}},
    "evaluation": {
      "type": "object",
      "required": ["pass", "coverage", "authority_precision", "scope_violations", "stop_reason"],
      "properties": {
        "pass": {"type": "boolean"},
        "coverage": {"type": "number", "minimum": 0, "maximum": 1},
        "authority_precision": {"type": "number", "minimum": 0, "maximum": 1},
        "scope_violations": {"type": "integer", "minimum": 0},
        "stop_reason": {"type": "string"}
      }
    },
    "safety": {
      "type": "object",
      "required": ["scope_gate_applied", "candidate_writeback_only"],
      "properties": {
        "scope_gate_applied": {"const": true},
        "candidate_writeback_only": {"const": true}
      }
    },
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "output_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  },
  "$defs": {
    "versionedContract": {
      "type": "object",
      "required": ["name", "version", "hash"],
      "properties": {
        "name": {"type": "string"},
        "version": {"type": "string"},
        "hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "contextItem": {
      "type": "object",
      "required": ["source_ref", "source_version", "authority_class", "summary", "content_hash", "token_estimate", "score"],
      "properties": {
        "source_ref": {"type": "string"},
        "source_version": {"type": "string"},
        "authority_class": {"type": "string"},
        "summary": {"type": "string"},
        "content_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "token_estimate": {"type": "integer", "minimum": 0},
        "score": {"type": "number", "minimum": 0}
      }
    },
    "excludedItem": {
      "type": "object",
      "required": ["source_ref", "reason_code", "reason"],
      "properties": {
        "source_ref": {"type": "string"},
        "reason_code": {"type": "string"},
        "reason": {"type": "string"}
      }
    },
    "iteration": {
      "type": "object",
      "required": ["iteration", "retrieval_mode", "coverage", "authority_precision", "marginal_gain", "latency_ms", "checkpoint_hash", "decision"],
      "properties": {
        "iteration": {"type": "integer", "minimum": 1},
        "retrieval_mode": {"type": "string"},
        "coverage": {"type": "number"},
        "authority_precision": {"type": "number"},
        "marginal_gain": {"type": "number"},
        "latency_ms": {"type": "number", "minimum": 0},
        "checkpoint_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "decision": {"type": "string"}
      }
    }
  }
}
