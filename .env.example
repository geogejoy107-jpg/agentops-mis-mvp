# This MVP is local-first. External writes/runs are disabled by default.
# Keep real keys out of source control.
APP_ENV=local
DATABASE_URL=file:./agentops_mis.db
EXTERNAL_CALLS_ENABLED=false
HIDDEN_TELEMETRY_ENABLED=false

# Optional Notion export connector.
# If unset, /api/integrations/notion/export-report returns a dry-run preview only.
NOTION_TOKEN=
NOTION_PARENT_PAGE_ID=
NOTION_DATABASE_ID=
NOTION_VERSION=2022-06-28

# Optional product-style export mode. Only works for Notion tokens that are allowed
# to create workspace-level private pages, such as supported public integrations or
# personal access tokens. Internal integrations usually still need a parent page or database.
NOTION_WORKSPACE_PRIVATE_EXPORT=false

# Optional Hermes / Agnesfallback runtime connectors.
# Health checks are local-only. Real model runs stay disabled unless both env
# and request confirmation are explicit.
HERMES_GATEWAY_URL=http://127.0.0.1:8642
HERMES_PROFILE=default
HERMES_RUNTIME_MODE=health_only
HERMES_ALLOW_REAL_RUN=false
HERMES_REQUIRE_CONFIRM_RUN=true

AGNESFALLBACK_BIN=~/.local/bin/agnesfallback
AGNESFALLBACK_GATEWAY_URL=http://127.0.0.1:8643
AGNESFALLBACK_PROFILE=agnesfallback
