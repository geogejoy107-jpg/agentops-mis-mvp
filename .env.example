# This MVP does not call external APIs.
# Keep real keys out of source control.
APP_ENV=local
DATABASE_URL=file:./agentops_mis.db
EXTERNAL_CALLS_ENABLED=false
HIDDEN_TELEMETRY_ENABLED=false

# Optional Notion export connector.
# If unset, /api/integrations/notion/export-report returns a dry-run preview only.
NOTION_TOKEN=
NOTION_PARENT_PAGE_ID=
NOTION_DATABASE_ID=
NOTION_VERSION=2022-06-28
