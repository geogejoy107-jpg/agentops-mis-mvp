+def _fetch_mis_json(path: str):
+    """Fetch safe public demo data from local AgentOps MIS only."""
+    url = f"{AGENTOPS_MIS_API_BASE}{path}"
+    req = urllib.request.Request(url, headers={"Accept": "application/json"})
+    with urllib.request.urlopen(req, timeout=1.4) as resp:
+        return json.loads(resp.read().decode("utf-8"))
+
+
+def _mis_agent_state(agent: dict, perf: dict | None) -> str:
+    status = str(agent.get("status") or "idle")
+    runtime = str(agent.get("runtime_type") or "")
+    failures = int((perf or {}).get("failures") or 0)
+    total_runs = int((perf or {}).get("total_runs") or 0)
+    approvals = int((perf or {}).get("approval_required_count") or 0)
+    if status in {"error", "disabled"}:
+        return "error"
+    if failures and total_runs and failures / max(total_runs, 1) >= 0.45:
+        return "error"
+    if approvals > 0:
+        return "syncing"
+    if status == "running":
+        return "executing"
+    if total_runs > 0:
+        return "executing" if runtime in {"openclaw", "hermes"} else "writing"
+    return "idle"
+
+
+def _map_mis_agents_for_room() -> list[dict]:
+    try:
+        agents = _fetch_mis_json("/agents")
+        metrics = _fetch_mis_json("/dashboard/metrics")
+    except Exception:
+        return []
+
+    perf_by_id = {
+        str(row.get("agent_id")): row
+        for row in (metrics.get("agent_performance_summary") or [])
+        if isinstance(row, dict)
+    }
+    preferred = sorted(
+        [a for a in agents if isinstance(a, dict)],
+        key=lambda a: (
+            0 if str(a.get("runtime_type") or "") in {"openclaw", "hermes"} else 1,
+            -int((perf_by_id.get(str(a.get("agent_id"))) or {}).get("total_runs") or 0),
+            str(a.get("name") or ""),
+        ),
+    )
+
+    mapped = []
+    for idx, agent in enumerate(preferred[:AGENTOPS_MIS_AGENT_LIMIT]):
+        agent_id = str(agent.get("agent_id") or f"agent_{idx}")
+        perf = perf_by_id.get(agent_id) or {}
+        state = _mis_agent_state(agent, perf)
+        runtime = str(agent.get("runtime_type") or "runtime")
+        total_runs = int(perf.get("total_runs") or 0)
+        success = float(perf.get("success_rate") or 0)
+        failures = int(perf.get("failures") or 0)
+        approvals = int(perf.get("approval_required_count") or 0)
+        detail = f"{runtime} · runs {total_runs} · success {round(success * 100)}% · failures {failures}"
+        if approvals:
+            detail += f" · approvals {approvals}"
+        mapped.append({
+            "agentId": f"mis_{_safe_agent_id(agent_id)}",
+            "name": str(agent.get("name") or agent_id).replace("OpenClaw ", "OC "),
+            "isMain": False,
+            "state": state,
+            "detail": detail,
+            "bubbleText": detail,
+            "updated_at": datetime.now().isoformat(),
+            "area": state_to_area(state),
+            "source": "agentops-mis",
+            "joinKey": None,
+            "authStatus": "approved",
+            "authExpiresAt": None,
+            "lastPushAt": datetime.now().isoformat(),
+            "avatar": f"guest_anim_{(idx % 6) + 1}",
+            "misAgentId": agent_id,
+            "runtimeType": runtime,
+            "totalRuns": total_runs,
+            "successRate": success,
+            "failures": failures,
+            "approvalCount": approvals,
+        })
+    return mapped
+
